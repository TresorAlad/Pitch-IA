# Veille tech insights : HN API (défaut activé si internet sortant). Sur VM sans sortie web :
# TECH_TRENDS_OFFLINE=true

# Frontend - laisser vide en dev (proxy Vite), URL API en prod si besoin
# VITE_API_URL=
